{
  "name": "my-wajiha-theme",
  "version": "1.0.0",
  "author": "",
  "description": "A custom Wajiha theme scaffolded against the Wajiha Design System tokens. Tenant brand colour cascades through --brand-primary-hex.",
  "sdk_version": "^1.1.0",
  "locales": ["en", "ar"],
  "settings": [
    {
      "key": "hero_title",
      "type": "text",
      "label": { "en": "Hero Title", "ar": "\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0628\u0637\u0644" },
      "default": "Welcome to our Developer Portal",
      "maxLength": 120
    },
    {
      "key": "hero_subtitle",
      "type": "text",
      "label": { "en": "Hero Subtitle", "ar": "\u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0641\u0631\u0639\u064A" },
      "default": "Explore our APIs and build amazing integrations.",
      "maxLength": 200
    },
    {
      "key": "primary_color",
      "type": "color",
      "label": { "en": "Primary Color", "ar": "\u0627\u0644\u0644\u0648\u0646 \u0627\u0644\u0623\u0633\u0627\u0633\u064A" },
      "default": "#0e6e6e"
    },
    {
      "key": "show_featured_products",
      "type": "boolean",
      "label": { "en": "Show Featured Products", "ar": "\u0639\u0631\u0636 \u0627\u0644\u0645\u0646\u062A\u062C\u0627\u062A \u0627\u0644\u0645\u0645\u064A\u0632\u0629" },
      "default": true
    },
    {
      "key": "products_per_row",
      "type": "number",
      "label": { "en": "Products Per Row", "ar": "\u0639\u062F\u062F \u0627\u0644\u0645\u0646\u062A\u062C\u0627\u062A \u0641\u064A \u0627\u0644\u0635\u0641" },
      "default": 3,
      "min": 1,
      "max": 4
    },
    {
      "key": "footer_layout",
      "type": "select",
      "label": { "en": "Footer Layout", "ar": "\u062A\u062E\u0637\u064A\u0637 \u0627\u0644\u062A\u0630\u064A\u064A\u0644" },
      "default": "simple",
      "options": [
        { "value": "simple", "label": { "en": "Simple", "ar": "\u0628\u0633\u064A\u0637" } },
        { "value": "detailed", "label": { "en": "Detailed", "ar": "\u0645\u0641\u0635\u0644" } }
      ]
    }
  ]
}
