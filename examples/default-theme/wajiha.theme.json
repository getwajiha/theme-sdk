{
  "name": "Wajiha Default",
  "version": "1.1.0",
  "author": "Wajiha",
  "description": "The reference Wajiha storefront theme — light-first canvas built on the Wajiha Design System tokens. Tenant brand colour cascades through --brand-primary-hex.",
  "sdk_version": "^1.1.0",
  "settings": [
    { "key": "hero_title", "type": "text", "label": { "en": "Hero Title", "ar": "عنوان البطل" }, "default": "Welcome to our platform" },
    { "key": "hero_subtitle", "type": "text", "label": { "en": "Hero Subtitle", "ar": "العنوان الفرعي" }, "default": "Build, deploy, and manage your APIs with ease" },
    { "key": "show_products", "type": "boolean", "label": { "en": "Show Products on Homepage", "ar": "إظهار المنتجات في الصفحة الرئيسية" }, "default": true },
    { "key": "max_products", "type": "number", "label": { "en": "Max Products on Homepage", "ar": "الحد الأقصى للمنتجات" }, "default": 6 },
    { "key": "hero_image", "type": "image", "label": { "en": "Hero Background Image", "ar": "صورة خلفية البطل" }, "default": null },
    {
      "key": "layout_style",
      "type": "select",
      "label": { "en": "Layout Style", "ar": "نمط التخطيط" },
      "options": [
        { "value": "centered", "label": { "en": "Centered", "ar": "متمركز" } },
        { "value": "wide", "label": { "en": "Wide", "ar": "عريض" } }
      ],
      "default": "centered"
    },
    {
      "key": "nav_main",
      "type": "array",
      "item_type": "nav-item",
      "label": { "en": "Main Navigation", "ar": "التنقل الرئيسي" },
      "default": [
        { "label": { "en": "Home", "ar": "الرئيسية" }, "url": "/" },
        { "label": { "en": "Docs", "ar": "التوثيق" }, "url": "/products" }
      ],
      "maxItems": 50,
      "maxLength": 200
    },
    {
      "key": "nav_footer",
      "type": "array",
      "item_type": "nav-item",
      "label": { "en": "Footer Navigation", "ar": "تنقل التذييل" },
      "default": [],
      "maxItems": 50,
      "maxLength": 200
    }
  ],
  "routes": {
    "/": "templates/index",
    "/products": "templates/products"
  },
  "locales": ["en", "ar"],
  "keycloak": {
    "customCSS": true,
    "reactBundle": true
  }
}
